<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Fila superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Icono servicio -->
        <TextView
            android:id="@+id/tvIconoServicio"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="24sp"
            android:background="@color/hueso"
            android:layout_marginEnd="12dp"/>

        <!-- Nombre y prestador -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nombre_servicio"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/Texto1"/>

            <TextView
                android:id="@+id/tvPrestadorServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/prestador_servicio"
                android:textSize="12sp"
                android:textColor="@color/gris"/>

        </LinearLayout>

        <!-- Precio y estado -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/precio_servicio"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/morado"/>

            <TextView
                android:id="@+id/tvEstadoServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/estado_activo"
                android:textSize="11sp"
                android:textColor="@color/verde_oscuro"
                android:background="@color/blanco_suave"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Reporte -->
    <TextView
        android:id="@+id/tvReporte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reporte_descripcion"
        android:textSize="12sp"
        android:textColor="@color/dorado"
        android:background="@color/hueso"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

    <!-- Calificación y reseñas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvCalificacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/calificacion_servicio"
            android:textSize="12sp"
            android:textColor="@color/Texto1"/>

        <TextView
            android:id="@+id/tvResenas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/resenas_servicio"
            android:textSize="12sp"
            android:textColor="@color/Texto1"/>

        <TextView
            android:id="@+id/tvReservas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reservas_servicio"
            android:textSize="12sp"
            android:textColor="@color/Texto1"/>

    </LinearLayout>

    <!-- Botones acción -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="3">

        <Button
            android:id="@+id/btnVerServicio"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/btn_ver"
            android:backgroundTint="@color/blanco_suave"
            android:textColor="@color/morado"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnAccion1"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/btn_pausar"
            android:backgroundTint="@color/hueso"
            android:textColor="@color/dorado"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnAccion2"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/btn_eliminar"
            android:backgroundTint="@color/rojo_claro"
            android:textColor="@color/rojo_caida"
            android:textSize="11sp"/>

    </LinearLayout>

</LinearLayout>