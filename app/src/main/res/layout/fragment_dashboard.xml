<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/pantalla">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header morado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/morado_tarjetas"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/panel_de_control"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/administrador"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnNotificaciones"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_dialog_info"
                android:background="@color/morado_opaco"
                app:tint="@color/white"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btnPerfil"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@color/morado_opaco"
                app:tint="@color/white"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tarjeta bienvenida -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/morado_tarjetas"
                android:padding="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_bienvenida"
                    android:textColor="@color/white"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvNombreAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_fragment"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/administrador_cuenta"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:background="@color/morado_opaco"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sistema_activo"
                        android:textColor="@color/verde_claro"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Tarjetas estadísticas fila 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/users"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvUsuariosTotales"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_usuarios"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/Texto1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_usuarios1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_usuarios1_1"
                        android:textSize="11sp"
                        android:textColor="@color/verde_claro"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/service"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPrestadores"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_prestadores"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/Texto1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_prestadores1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_prestadores1_1"
                        android:textSize="11sp"
                        android:textColor="@color/verde_claro"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Tarjetas estadísticas fila 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/report"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvServicios"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_servicios"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/Texto1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_servicios1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_servicios1_1"
                        android:textSize="11sp"
                        android:textColor="@color/verde_claro"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/logout"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvIngresos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_ingresos"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/Texto1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_ingresos1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_dashboard_ingresos1_1"
                        android:textSize="11sp"
                        android:textColor="@color/verde_claro"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Acciones rápidas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/acciones_r_pidas"
                android:textSize="12sp"
                android:textColor="@color/blanco_filtro"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnUsuarios"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_usuarios"
                    android:backgroundTint="@color/morado"
                    android:textColor="@color/white"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnServicios"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_servicios"
                    android:backgroundTint="#FF8F00"
                    android:textColor="@color/white"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnReportes"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_reportes"
                    android:backgroundTint="@color/blanco_suave"
                    android:textColor="@color/morado"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnConfiguracion"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_configuracion"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/Texto1"/>

            </LinearLayout>

            <!-- Usuarios Recientes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/servicios_recientes"
                android:textSize="12sp"
                android:textColor="@color/blanco_filtro"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUsuariosRecientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <Button
                android:id="@+id/btnVerTodosUsuarios"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_ver_usuarios"
                android:backgroundTint="@color/morado"
                android:textColor="@color/white"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>