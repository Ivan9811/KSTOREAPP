<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">


    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#4A0E8F"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/panel_de_control"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_reportes"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnExportarHeader"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="#5C1A9E"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Filtros de tiempo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@android:color/white"
                android:weightSum="4">

                <Button
                    android:id="@+id/btn7dias"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/text_estadistica"
                    android:backgroundTint="@android:color/white"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <Button
                    android:id="@+id/btnEsteMes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/text_estadistica1"
                    android:backgroundTint="#6200EE"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"/>

                <Button
                    android:id="@+id/btnTrimestre"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/text_estadistica2"
                    android:backgroundTint="@android:color/white"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <Button
                    android:id="@+id/btnAnio"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/text_estadistica3"
                    android:backgroundTint="@android:color/white"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

            </LinearLayout>

    <!-- Tarjeta ingresos con gráfica -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#4A0E8F"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tarjeta_ingreso"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvIngresosTotales"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/targeta_ingreso1"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/targeta_ingreso2"
            android:textColor="#00E676"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <!-- Gráfica de barras manual -->
        <LinearLayout
            android:id="@+id/layoutBarras"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="12dp"
            android:weightSum="10">

            <View
                android:layout_width="0dp"
                android:layout_height="15dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#80FFFFFF"
                android:layout_marginEnd="6dp"/>
            <!-- Última barra resaltada en blanco -->
            <View
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:layout_marginEnd="6dp"/>

        </LinearLayout>

    </LinearLayout>
            <!-- Métricas clave -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/metricas"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Servicios completados -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/servicios_icon"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvServiciosCompletados"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/servicios"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/servicios1_1"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/servicios1_2"
                        android:textSize="11sp"
                        android:textColor="#00C853"/>

                </LinearLayout>

                <!-- Nuevos usuarios -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usuarios_icon"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvNuevosUsuarios"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usuarios1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usuarios1_2"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ususarios1_3"
                        android:textSize="11sp"
                        android:textColor="#00C853"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="8dp">

                <!-- Calificación -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calificacion_icon"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvCalificacionProm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calificacion1_1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calificacion1_2"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calificacion1_3"
                        android:textSize="11sp"
                        android:textColor="#00C853"/>

                </LinearLayout>

                <!-- Tasa de retención -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tasa_icon"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvTasaRetencion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tasa1_1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tasa1_2"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tasa1_3"
                        android:textSize="11sp"
                        android:textColor="#D32F2F"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Servicios por categoría -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/estadisticas_categoria"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <!-- Electricistas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/estadisticas_electricista1"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_electricista1_1"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="34"
                    android:progressTint="#6200EE"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_marginBottom="12dp"/>

                <!-- Limpieza -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/estadistica_limpieza1"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadistica_limpieza1_2"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="28"
                    android:progressTint="#FF8F00"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_marginBottom="12dp"/>

                <!-- Plomeros -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/estadistica_plomero1"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadistica_plomero1_2"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="18"
                    android:progressTint="#00C853"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_marginBottom="12dp"/>

                <!-- Tech -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/estadistica_tech1"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadistica_tech1_2"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="12"
                    android:progressTint="#E91E63"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_marginBottom="12dp"/>

                <!-- Pintura -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/estadistica_pintura_otros1"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadistica_pintura_otros1_2"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="8"
                    android:progressTint="#2196F3"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>

            </LinearLayout>

            <!-- Top Prestadores -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/Top_prestadores"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <!-- Prestador 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prestador_icon1"
                        android:textSize="20sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="@string/prestador1_1"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="#6200EE"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/prestador1_3"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/prestador1_4"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prestador1_5"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6200EE"/>

                </LinearLayout>

                <!-- Prestador 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prestador_icon2"
                        android:textSize="20sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="@string/prestador2_1"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="#E91E63"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/prestador2_2"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/prestador2_3"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prestador2_4"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6200EE"/>

                </LinearLayout>

                <!-- Prestador 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prestasdor_icon3"
                        android:textSize="20sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="@string/prestador3_1"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="#00C853"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/prestador3_2"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/prestador3_3"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prestador3_4"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6200EE"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Botón exportar -->
            <Button
                android:id="@+id/btnExportarPDF"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_pdf"
                android:backgroundTint="#6200EE"
                android:textColor="@android:color/white"
                android:textSize="15sp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
