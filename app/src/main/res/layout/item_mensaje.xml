<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar con punto online -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp">

        <TextView
            android:id="@+id/tvIniciales"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_avatar_purple"/>

        <View
            android:id="@+id/dotonline"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/dot_green"
            android:layout_gravity="bottom|end"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Nombre + Mensaje -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/Texto1"/>

        <TextView
            android:id="@+id/ultimoMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/gris"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Hora + Badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/hora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/gris"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/bg_avatar_purple"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>