<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/morado"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/registro_profesional"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nombre_completo"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_nombre1"
                android:inputType="textPersonName"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/correo_electr_nico"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_correo"
                android:inputType="textEmailAddress"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Teléfono -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tel_fono"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_telefono"
                android:inputType="phone"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Ciudad -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ciudad"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etCiudad"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_ciudad1"
                android:inputType="textCapWords"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Contraseña -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contrase_a"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_contraseña"
                android:inputType="textPassword"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Categorías -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/seleccion_categoria"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Fila 1 categorías -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/catElectricista"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rayo_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/electricista"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catPlomero"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/plomero_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/plomero"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catCarpintero"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/carpintero_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/carpintero"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Fila 2 categorías -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/catPintor"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pintor_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pintor"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catDev"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catLimpieza"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/limpieza_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/limpieza"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Fila 3 categorías -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/catJardin"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/jardin_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/jard_n"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catMecanico"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mecanico_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mec_nico"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catArquitecto"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_tipo">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/arquitecto_icon"
                        android:textSize="24sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/arquitecto"
                        android:textSize="11sp"
                        android:textColor="@color/Texto1"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/descripci_n_profesional"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="@string/cu_ntanos_tu_experiencia"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="32dp"/>

            <!-- Botón crear cuenta -->
            <Button
                android:id="@+id/btnCrearCuenta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/crear_cuenta_profesional"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/morado"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>