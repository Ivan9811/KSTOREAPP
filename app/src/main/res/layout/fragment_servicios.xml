<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pantalla">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_tarjetas"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/panel_de_control"
                android:textColor="@color/white"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fragment_servicio"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@color/morado_opaco"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/btnDescargar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="@color/morado_opaco"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Buscador -->
            <EditText
                android:id="@+id/etBuscarServicio"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/text_buscador"
                android:paddingStart="16dp"
                android:inputType="text"
                android:background="@color/white"/>

            <!-- Filtros -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnTodos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_filtro"
                        android:backgroundTint="@color/morado"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnActivos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_filtro1"
                        android:backgroundTint="@color/white"
                        android:textColor="@color/Texto1"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnRevision"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_filtro2"
                        android:backgroundTint="@color/white"
                        android:textColor="@color/Texto1"
                        android:textSize="12sp"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Estadísticas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvTotalActivos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_servicio1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/morado"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_servicio1_1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvTotalRevision"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_servicio2"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/dorado"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadistica_servicio2_1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvTotalReportados"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_servicio3"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/rojo_caida"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_servicio3_1"
                        android:textSize="11sp"
                        android:textColor="@color/blanco_filtro"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Botones aprobar/reportados -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnAprobarPendientes"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_pendientes"
                    android:backgroundTint="@color/verde_claro"
                    android:textColor="@color/verde_oscuro"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnVerReportados"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_aprobados"
                    android:backgroundTint="@color/rojo_claro"
                    android:textColor="@color/rojo_caida"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- Título lista -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/servicios_recientes"
                android:textSize="12sp"
                android:textColor="@color/blanco_filtro"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Lista servicios -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>