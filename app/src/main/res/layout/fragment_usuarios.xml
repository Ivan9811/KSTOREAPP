<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pantalla">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_tarjetas"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/panel_de_control"
            android:textColor="@color/white"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/usuarios_fragment"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Buscador -->
            <EditText
                android:id="@+id/etBuscar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/buscador_usuario"
                android:paddingStart="16dp"
                android:drawableStart="@drawable/search"
                android:inputType="text"/>

            <!-- Filtros -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnTodos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_todos"
                        android:backgroundTint="@color/morado"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>

                    <Button
                        android:id="@+id/btnClientes"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_clientes"
                        android:backgroundTint="@color/white"
                        android:textColor="@color/Texto1"
                        android:textSize="12sp"/>

                    <Button
                        android:id="@+id/btnPrestadores"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_prestadores"
                        android:backgroundTint="@color/white"
                        android:textColor="@color/Texto1"
                        android:textSize="12sp"/>

                    <Button
                        android:id="@+id/btnPendientes"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_pendiente"
                        android:backgroundTint="@color/white"
                        android:textColor="@color/Texto1"
                        android:textSize="12sp"/>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Estadísticas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvTotalClientes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_usuario1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_usuario1_1"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvTotalPrestadores"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_usuario2"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/Texto1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_usuario2_1"
                        android:textSize="12sp"
                        android:textColor="@color/blanco_filtro"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvTotalPendientes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_usuario3"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/dorado"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estadisticas_usuario3_1"
                        android:textSize="12sp"
                        android:textColor="@color/blanco_filtro"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Alerta prestadores pendientes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#FFF3CD"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/prestadores_pendientes"
                    android:textColor="#856404"
                    android:textSize="13sp"/>

                <Button
                    android:id="@+id/btnRevisar"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_revisar"
                    android:backgroundTint="#FF6B00"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Título lista -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/usuarios_recientes"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"/>

            <!-- Lista de usuarios -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUsuarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="8dp"/>

            <!-- Cargar más -->
            <Button
                android:id="@+id/btnCargarMas"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/cargar_usuarios"
                android:backgroundTint="@android:color/white"
                android:textColor="#6200EE"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>