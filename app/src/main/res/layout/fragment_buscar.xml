<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/white"
        android:layout_marginTop="25dp">

        <ImageView
            android:id="@+id/btnVolver"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/arrow_back"
            android:padding="6dp"
            app:tint="@color/Texto1"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/b_squeda"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/Texto1"
            android:gravity="center"/>

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== BUSCADOR ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_search_bar">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/search"
                    app:tint="@color/gris"/>

                <EditText
                    android:id="@+id/etBuscar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/buscar_por_categor_a_o_nombre"
                    android:textColorHint="@color/gris"
                    android:textSize="13sp"
                    android:textColor="@color/Texto1"
                    android:background="@null"
                    android:layout_marginStart="8dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"/>

            </LinearLayout>

            <!-- ===== FILTROS RÁPIDOS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtros_r_pidos"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/Texto1"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <!-- Fila 1 de chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Todos (seleccionado) -->
                <TextView
                    android:id="@+id/chipTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="@string/todos"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_selected"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/bolt"
                        app:tint="@color/morado_tarjetas"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/electricista"
                        android:textSize="12sp"
                        android:textColor="@color/morado_tarjetas"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/plumbing"
                        app:tint="@color/morado_tarjetas"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/plomero"
                        android:textSize="12sp"
                        android:textColor="@color/morado_tarjetas"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Fila 2 de chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/handyman"
                        app:tint="@color/morado_tarjetas"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/carpintero"
                        android:textSize="12sp"
                        android:textColor="@color/morado_tarjetas"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/paint"
                        app:tint="@color/morado_tarjetas"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pintor"
                        android:textSize="12sp"
                        android:textColor="@color/morado_tarjetas"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/computer"
                        app:tint="@color/morado_tarjetas"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tech"
                        android:textSize="12sp"
                        android:textColor="@color/morado_tarjetas"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ===== ORDENAR POR ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ordenar_por"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/Texto1"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_outline">

                <TextView
                    android:id="@+id/tvOrdenar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mayor_calificaci_n"
                    android:textSize="13sp"
                    android:textColor="@color/Texto1"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/expand"
                    app:tint="@color/gris"/>

            </LinearLayout>

            <!-- ===== CALIFICACIÓN MÍNIMA ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/calificaci_n_m_nima"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/Texto1"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Todas -->
                <TextView
                    android:id="@+id/chipCalTodas"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="@string/todas"
                    android:textSize="12sp"
                    android:textColor="@color/gris"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"/>

                <!-- 4+ -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/star"
                        app:tint="@color/dorado"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_4"
                        android:textSize="12sp"
                        android:textColor="@color/Texto1"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- 4.5+ (seleccionado) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_selected">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/star"
                        app:tint="@color/white"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_4_5"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- 5.0 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_chip_unselected">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/star"
                        app:tint="@color/dorado"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_5_0"
                        android:textSize="12sp"
                        android:textColor="@color/Texto1"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ===== BOTÓN BUSCAR ===== -->
            <Button
                android:id="@+id/btnBuscar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/buscar"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>