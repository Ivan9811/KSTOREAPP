<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/morado"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/registro_cliente"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nombre_completo"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_nombre"
                android:inputType="textPersonName"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/correo_electr_nico"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_correo"
                android:inputType="textEmailAddress"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Teléfono -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tel_fono"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_telefono"
                android:inputType="phone"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Ciudad -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ciudad"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etCiudad"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_ciudad"
                android:inputType="textCapWords"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Contraseña -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contrase_a"
                android:textSize="13sp"
                android:textColor="@color/Texto1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/ejemplo_contraseña"
                android:inputType="textPassword"
                android:background="@drawable/input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="32dp"/>

            <!-- Botón crear cuenta -->
            <Button
                android:id="@+id/btnCrearCuenta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/crear_cuenta_de_cliente"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/morado"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>