<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Contenido scrolleable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="72dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER MORADO ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/morado_opaco">

                <!-- Botón volver -->
                <ImageView
                    android:id="@+id/btnVolver"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/arrow_back"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle_gray"
                    android:layout_margin="16dp"
                    android:layout_gravity="top|start"
                    app:tint="@color/white"/>

                <!-- Favorito -->
                <ImageView
                    android:id="@+id/btnFavorito"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/favorito"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle_gray"
                    android:layout_margin="16dp"
                    android:layout_gravity="top|end"
                    app:tint="@color/white"/>

            </FrameLayout>

            <!-- ===== CONTENIDO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Profesional -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="@string/jr"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar_purple"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/juan_rodr_guez"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/Texto1"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/calificacion"
                            android:textSize="12sp"
                            android:textColor="@color/dorado"/>

                    </LinearLayout>

                    <!-- Badge Verificado -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/verificado"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_chip_selected"/>

                </LinearLayout>

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/instalaci_n_el_ctrica_residencial"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/Texto1"
                    android:layout_marginTop="12dp"/>

                <!-- Precio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_50_hora"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/morado_tarjetas"
                    android:layout_marginTop="4dp"/>

                <!-- Tags -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bogot"
                        android:textSize="11sp"
                        android:textColor="@color/morado_tarjetas"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/electricista"
                        android:textSize="11sp"
                        android:textColor="@color/morado_tarjetas"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/disponible_hoy"
                        android:textSize="11sp"
                        android:textColor="@color/morado_tarjetas"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_chip_unselected"/>

                </LinearLayout>

                <!-- Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/descripci_n_del_servicio"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/Texto1"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/electricista_certificado_con_m_s_de_10_a_os_de_experiencia_en_instalaciones_el_ctricas_residenciales_y_comerciales_ofrezco_servicios_de_calidad_garantizados_trabajando_con_las_mejores_pr_cticas_de_seguridad_y_cumpliendo_todas_las_normativas_vigentes"
                    android:textSize="13sp"
                    android:textColor="@color/gris"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="6dp"/>

                <!-- ¿Qué incluye? -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/qu_incluye"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/Texto1"
                    android:layout_marginTop="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/search"
                        app:tint="@color/morado_tarjetas"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/diagn_stico_y_cotizaci_n_gratuita"
                        android:textSize="13sp"
                        android:textColor="@color/Texto1"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ===== BARRA INFERIOR FIJA ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:elevation="8dp"
        android:layout_gravity="bottom">

        <!-- Botón Chat -->
        <ImageView
            android:id="@+id/btnChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/mensajes"
            android:padding="8dp"
            android:background="@drawable/bg_chip_unselected"
            android:layout_marginEnd="8dp"
            app:tint="@color/morado_tarjetas"/>

        <!-- Botón Calendario -->
        <ImageView
            android:id="@+id/btnCalendario"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/calendar"
            android:padding="8dp"
            android:background="@drawable/bg_chip_orange"
            android:layout_marginEnd="8dp"
            app:tint="@color/white"/>

        <!-- Botón Contratar -->
        <Button
            android:id="@+id/btnContratar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/contratar_agendar"
            android:textSize="13sp"
            android:backgroundTint="@color/morado_tarjetas"
            android:textColor="@color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>