<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <!-- ===== 1. HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/location"
                        app:tint="#FF0000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bogotá, Colombia"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="K-STORE"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
            </LinearLayout>

            <!-- Campana con badge -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/notificacion"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle_gray"/>

                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_red"
                    android:layout_gravity="top|end"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ===== 2. BUSCADOR ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/search"
                app:tint="#AAAAAA"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscar servicios o profesionales..."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- ===== 3. FILTROS ===== -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Todos"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_selected"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="⚡ Electricista"
                    android:textColor="#4A0E8F"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_unselected"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🔧 Plomero"
                    android:textColor="#4A0E8F"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_unselected"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🔨 Carpintero"
                    android:textColor="#4A0E8F"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_unselected"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ===== 4. BANNER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:padding="20dp"
            android:background="@drawable/bg_banner_purple">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Encuentra tu profesional ideal! 🎯"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Más de 5,000 profesionales verificados listos para ayudarte hoy"
                android:textColor="#E0D0FF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Explorar servicios"
                android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#FF9500"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- ===== 5. CATEGORÍAS ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categorías populares"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:weightSum="5">

            <!-- Categoria item x5 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="⚡" android:textSize="24sp" android:gravity="center"
                    android:background="@drawable/bg_category_circle"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Electricista" android:textSize="10sp" android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="🚿" android:textSize="24sp" android:gravity="center"
                    android:background="@drawable/bg_category_circle"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Plomero" android:textSize="10sp" android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="🔨" android:textSize="24sp" android:gravity="center"
                    android:background="@drawable/bg_category_circle"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Carpintero" android:textSize="10sp" android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="🎨" android:textSize="24sp" android:gravity="center"
                    android:background="@drawable/bg_category_circle"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pintor" android:textSize="10sp" android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="💻" android:textSize="24sp" android:gravity="center"
                    android:background="@drawable/bg_category_circle"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tech" android:textSize="10sp" android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ===== 6. SERVICIOS DESTACADOS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:gravity="center_vertical"
            android:layout_margin="5dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Servicios destacados"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver todos"
                android:textColor="#4A0E8F"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Tarjeta de servicio -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:id="@+id/cardServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Imagen del servicio -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="#6B2FCC">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electricista"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_chip_white"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"/>
                </FrameLayout>

                <!-- Info del profesional -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Avatar -->
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="JR"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:background="@drawable/bg_avatar_purple"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Juan Rodríguez ✓"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:textColor="#1A1A1A"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐⭐⭐⭐⭐ 4.9 (127)"
                                android:textSize="12sp"
                                android:textColor="#FF9500"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instalación Eléctrica Residencial"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#4A0E8F"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electricista certificado con 10+ años de experiencia. Especializado en instalaciones residenciales y comerciales."
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>